<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Google Translate Language Codes</title>
<link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400&family=IBM+Plex+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #f5f4f0;
    --surface: #ffffff;
    --text: #1a1a1a;
    --muted: #888;
    --accent: #2563eb;
    --accent-light: #dbeafe;
    --border: #e5e5e5;
    --code-bg: #f0f0ec;
  }

  body {
    font-family: 'EB Garamond', serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    padding: 48px 24px;
  }

  header {
    max-width: 900px;
    margin: 0 auto 48px;
  }

  .eyebrow {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 12px;
  }

  h1 {
    font-size: clamp(28px, 5vw, 48px);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
  }

  .subtitle {
    color: var(--muted);
    font-size: 15px;
    font-weight: 400;
  }

  .controls {
    max-width: 900px;
    margin: 0 auto 24px;
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }

  .search-wrap {
    flex: 1;
    min-width: 200px;
    position: relative;
  }

  .search-wrap svg {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--muted);
    width: 16px;
    height: 16px;
    pointer-events: none;
  }

  input[type="text"] {
    width: 100%;
    padding: 10px 14px 10px 40px;
    border: 1.5px solid var(--border);
    border-radius: 10px;
    font-family: 'EB Garamond', serif;
    font-size: 14px;
    background: var(--surface);
    color: var(--text);
    outline: none;
    transition: border-color 0.15s;
  }

  input[type="text"]:focus {
    border-color: var(--accent);
  }

  .count {
    font-size: 13px;
    color: var(--muted);
    white-space: nowrap;
  }

  .grid {
    max-width: 900px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 10px;
  }

  .card {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: 12px;
    padding: 14px 16px;
    display: flex;
    align-items: center;
    gap: 12px;
    transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
    cursor: pointer;
    animation: fadeUp 0.4s ease both;
    position: relative;
  }

  .card:hover {
    border-color: var(--accent);
    box-shadow: 0 4px 16px rgba(37,99,235,0.08);
    transform: translateY(-2px);
  }

  .copy-hint {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 11px;
    color: var(--muted);
    opacity: 0;
    transition: opacity 0.15s;
    pointer-events: none;
  }

  .card:hover .copy-hint {
    opacity: 1;
  }

  .code {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    font-weight: 600;
    background: var(--code-bg);
    color: var(--accent);
    padding: 4px 8px;
    border-radius: 6px;
    letter-spacing: 0.04em;
    flex-shrink: 0;
    min-width: 36px;
    text-align: center;
  }

  .lang-name {
    font-size: 13px;
    font-weight: 500;
    color: var(--text);
    line-height: 1.3;
  }

  /* Modal */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.35);
    backdrop-filter: blur(4px);
    z-index: 100;
    align-items: center;
    justify-content: center;
  }

  .modal-overlay.open {
    display: flex;
  }

  .modal {
    background: var(--surface);
    border-radius: 16px;
    padding: 28px;
    max-width: 520px;
    width: calc(100% - 48px);
    box-shadow: 0 24px 64px rgba(0,0,0,0.15);
    animation: modalIn 0.2s ease both;
  }

  @keyframes modalIn {
    from { opacity: 0; transform: scale(0.95) translateY(8px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 6px;
  }

  .modal-lang {
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .modal-close {
    background: var(--code-bg);
    border: none;
    border-radius: 8px;
    width: 32px;
    height: 32px;
    font-size: 18px;
    cursor: pointer;
    color: var(--muted);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }

  .modal-close:hover {
    background: var(--border);
  }

  .modal-subtitle {
    font-size: 12px;
    color: var(--muted);
    margin-bottom: 20px;
  }

  .modal-code-wrap {
    background: #1e1e2e;
    border-radius: 10px;
    padding: 16px 18px;
    margin-bottom: 16px;
    position: relative;
  }

  .modal-code {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    color: #cdd6f4;
    white-space: pre-wrap;
    word-break: break-all;
    line-height: 1.6;
  }

  .modal-code .hl-func { color: #89b4fa; }
  .modal-code .hl-str { color: #a6e3a1; }
  .modal-code .hl-kw { color: #cba6f7; }
  .modal-code .hl-comment { color: #6c7086; font-style: italic; }
  .modal-code .hl-code { color: #f38ba8; }

  .modal-copy-btn {
    width: 100%;
    padding: 11px;
    background: var(--accent);
    color: white;
    border: none;
    border-radius: 10px;
    font-family: 'EB Garamond', serif;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s, transform 0.1s;
  }

  .modal-copy-btn:hover {
    background: #1d4ed8;
  }

  .modal-copy-btn:active {
    transform: scale(0.98);
  }

  .modal-copy-btn.success {
    background: #16a34a;
  }

  .hidden { display: none; }

  .no-results {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
    padding: 48px;
    color: var(--muted);
    font-size: 15px;
    display: none;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  footer {
    max-width: 900px;
    margin: 48px auto 0;
    padding-top: 24px;
    border-top: 1px solid var(--border);
    font-size: 12px;
    color: var(--muted);
  }
</style>
</head>
<body>

<header>
  <h1>Google Translate<br>Language Codes</h1>
  <p class="subtitle">All supported two-letter ISO 639-1 language codes</p>
</header>

<div class="controls">
  <div class="search-wrap">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
    </svg>
    <input type="text" id="search" placeholder="Search languages or codes…" oninput="filter()">
  </div>
  <span class="count" id="count"></span>
</div>

<div class="grid" id="grid"></div>
<div class="no-results" id="no-results">No languages found.</div>

<!-- Modal -->
<div class="modal-overlay" id="modal-overlay">
  <div class="modal">
    <div class="modal-header">
      <span class="modal-lang" id="modal-lang-name"></span>
      <button class="modal-close" onclick="closeModal()">×</button>
    </div>
    <div class="modal-subtitle">Click below to copy the gTTS code line</div>
    <div class="modal-code-wrap">
      <div class="modal-code" id="modal-code"></div>
    </div>
    <button class="modal-copy-btn" id="modal-copy-btn" onclick="copyCode()">Copy Code</button>
  </div>
</div>

<footer>
  Two-letter codes follow the ISO 639-1 standard. Source: Google Translate supported languages.
</footer>

<script>
const languages = [
  { code: "af", name: "Afrikaans" },
  { code: "sq", name: "Albanian" },
  { code: "am", name: "Amharic" },
