  { code: "tg", name: "Tajik" },
  { code: "ta", name: "Tamil" },
  { code: "tt", name: "Tatar" },
  { code: "te", name: "Telugu" },
  { code: "th", name: "Thai" },
  { code: "ti", name: "Tigrinya" },
  { code: "ts", name: "Tsonga" },
  { code: "tr", name: "Turkish" },
  { code: "tk", name: "Turkmen" },
  { code: "ak", name: "Twi (Akan)" },
  { code: "uk", name: "Ukrainian" },
  { code: "ur", name: "Urdu" },
  { code: "ug", name: "Uyghur" },
  { code: "uz", name: "Uzbek" },
  { code: "vi", name: "Vietnamese" },
  { code: "cy", name: "Welsh" },
  { code: "xh", name: "Xhosa" },
  { code: "yi", name: "Yiddish" },
  { code: "yo", name: "Yoruba" },
  { code: "zu", name: "Zulu" },
];

// Only truly two-letter codes
const twoLetter = languages.filter(l => l.code.length === 2);

const grid = document.getElementById('grid');
const countEl = document.getElementById('count');
const noResults = document.getElementById('no-results');

let currentCode = '';

function openModal(lang) {
  currentCode = `tts = gTTS(text=text, lang='${lang.code}') # ${lang.name}`;
  document.getElementById('modal-lang-name').textContent = lang.name;
  document.getElementById('modal-code').innerHTML =
    `<span class="hl-kw">tts</span> = <span class="hl-func">gTTS</span>(text=text, lang=<span class="hl-str">'${lang.code}'</span>) <span class="hl-comment"># ${lang.name}</span>`;
  const btn = document.getElementById('modal-copy-btn');
  btn.textContent = 'Copy Code';
  btn.classList.remove('success');
  document.getElementById('modal-overlay').classList.add('open');
}

function closeModal() {
  document.getElementById('modal-overlay').classList.remove('open');
}

function copyCode() {
  const btn = document.getElementById('modal-copy-btn');
  const ta = document.createElement('textarea');
  ta.value = currentCode;
  ta.style.position = 'fixed';
  ta.style.opacity = '0';
  document.body.appendChild(ta);
  ta.select();
  document.execCommand('copy');
  document.body.removeChild(ta);
  btn.textContent = '✓ Copied!';
  btn.classList.add('success');
  setTimeout(() => {
    btn.textContent = 'Copy Code';
    btn.classList.remove('success');
  }, 2000);
}

// Close on overlay click
document.getElementById('modal-overlay').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});

// Close on Escape
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

function render(list) {
  grid.innerHTML = '';
  list.forEach((lang, i) => {
    const card = document.createElement('div');
    card.className = 'card';
    card.style.animationDelay = `${Math.min(i * 15, 300)}ms`;
    card.innerHTML = `<span class="code">${lang.code}</span><span class="lang-name">${lang.name}</span><span class="copy-hint">view code</span>`;
    card.addEventListener('click', () => openModal(lang));
    grid.appendChild(card);
  });
  countEl.textContent = `${list.length} language${list.length !== 1 ? 's' : ''}`;
  noResults.style.display = list.length === 0 ? 'block' : 'none';
}

function filter() {
  const q = document.getElementById('search').value.toLowerCase().trim();
  const filtered = twoLetter.filter(l =>
    l.name.toLowerCase().includes(q) || l.code.toLowerCase().includes(q)
  );
  render(filtered);
}

render(twoLetter);
</script>
</body>
</html>